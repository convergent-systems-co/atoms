        "engine": "github-actions",
        "command": "echo 'All upstream checks green — proceeding to deploy.'",
        "timeout_seconds": 10
      },
      "condition": "${{ !contains(needs.*.result, 'failure') && !contains(needs.*.result, 'cancelled') }}",
      "on_failure": "fail",
      "authored_by": "convergent-systems-key",
