---
import Base from "../layouts/Base.astro";
import CatalogCard from "../components/CatalogCard.astro";
import { readFile } from "node:fs/promises";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";
import directory from "../../public/directory.json";

const HERE = dirname(fileURLToPath(import.meta.url));
let ecosystemCompositions: any[] = [];
try {
  const pipelinesRaw = await readFile(join(HERE, "../../public/pipelines.json"), "utf-8");
  const pipelines = JSON.parse(pipelinesRaw);
  const ecosystemIds: string[] = pipelines.ecosystem_compositions ?? [];
  ecosystemCompositions = (pipelines.workflow_compositions ?? []).filter((c: any) =>
    ecosystemIds.some((id: string) => (c.id ?? "").endsWith(id))
  );
} catch { /* pipelines.json not built yet — gracefully skip */ }

const live = directory.catalogs.filter((c: any) => c.status === "live");
const bootstrap = directory.catalogs.filter((c: any) => c.status === "bootstrap");

const totalAtoms = live.reduce((s: number, c: any) => s + (c.live?.atoms ?? 0), 0);
const totalCompositions = live.reduce((s: number, c: any) => s + (c.live?.compositions ?? 0), 0);
---
<Base title="Home" description="Directory of every *-atoms catalog in the Convergent Systems ecosystem.">
  <h1>atoms</h1>
  <p style="font-size: 1.125rem; color: var(--muted); max-width: 50rem;">
    The umbrella directory for every <code>*-atoms</code> catalog in the
    Convergent Systems ecosystem — typed, versioned, composable libraries of
    AI primitives. Each catalog is its own repository, its own release
    cycle, its own deployed site. This page is the central directory both
    humans and AI agents can use to discover what exists.
  </p>

  <section style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin: 2rem 0; padding: 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 0.5rem;">
    <div>
      <div style="font-size: 2rem; font-weight: 600; line-height: 1;">{directory.summary.total}</div>
      <div style="color: var(--muted); font-size: 0.875rem;">catalogs total · {directory.summary.live} live · {directory.summary.bootstrap} bootstrap</div>
    </div>
    <div>
      <div style="font-size: 2rem; font-weight: 600; line-height: 1;">{totalAtoms}</div>
      <div style="color: var(--muted); font-size: 0.875rem;">atoms across live catalogs</div>
    </div>
    <div>
      <div style="font-size: 2rem; font-weight: 600; line-height: 1;">{totalCompositions}</div>
      <div style="color: var(--muted); font-size: 0.875rem;">compositions across live catalogs</div>
    </div>
  </section>

  {live.length > 0 && (
    <section>
      <h2>Live catalogs</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr)); gap: 1rem; margin-top: 1rem;">
        {live.map((c: any) => <CatalogCard catalog={c} />)}
      </div>
    </section>
  )}

  {bootstrap.length > 0 && (
    <section style="margin-top: 3rem;">
      <h2>Bootstrap catalogs</h2>
      <p style="color: var(--muted); margin-bottom: 1rem;">Catalogs with schemas + intent declared but no live deploy yet.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr)); gap: 1rem;">
        {bootstrap.map((c: any) => <CatalogCard catalog={c} />)}
      </div>
    </section>
  )}

  {ecosystemCompositions.length > 0 && (
    <section style="margin-top: 3rem;">
      <h2>Powered by atoms</h2>
      <p style="color: var(--muted); margin-bottom: 1.25rem;">
        This ecosystem builds and deploys itself using the same atoms it catalogs.
        <a href="/pipelines/">See the full pipeline registry →</a>
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(24rem, 1fr)); gap: 0.75rem;">
        {ecosystemCompositions.map((comp: any) => (
          <div style="background: var(--card); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem;">
              <span style="font-size: 0.75rem; background: #e8f0e8; color: var(--live); padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-weight: 600;">workflow</span>
            </div>
            <div style="font-weight: 600; margin-bottom: 0.25rem;">{comp.name}</div>
            {comp.description && <p style="color: var(--muted); font-size: 0.8rem; margin: 0 0 0.5rem;">{comp.description}</p>}
            {comp.steps && comp.steps.length > 0 && (
              <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; align-items: center; font-size: 0.75rem;">
                {comp.steps.map((step: any, i: number) => (
                  <>
                    <code style="background: #f0f0f0; padding: 0.1rem 0.3rem; border-radius: 0.2rem;">{step.id}</code>
                    {i < comp.steps.length - 1 && <span style="color: var(--muted);">→</span>}
                  </>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <section style="margin-top: 3rem;">
    <h2>For AI agents</h2>
    <p style="color: var(--muted); margin-bottom: 1rem;">
      Two endpoints power AI discovery of this ecosystem. Start with <code>/ai/index.json</code> —
      it immediately points you to <code>/ai/instructions.md</code> which explains how to navigate
      all 25+ catalogs and what each atom type is for.
    </p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr)); gap: 0.75rem; margin-bottom: 1.25rem;">
      <div style="background: var(--card); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem;">
        <div style="font-weight: 600; margin-bottom: 0.25rem;"><a href="/ai/index.json"><code>/ai/index.json</code></a></div>
        <p style="color: var(--muted); font-size: 0.875rem; margin: 0;">
          Master AI directory — all catalogs with domain, AI endpoint URL, atom types, and description.
          First key is <code>instructions</code> pointing to instructions.md.
        </p>
      </div>
      <div style="background: var(--card); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem;">
        <div style="font-weight: 600; margin-bottom: 0.25rem;"><a href="/ai/instructions.md"><code>/ai/instructions.md</code></a></div>
        <p style="color: var(--muted); font-size: 0.875rem; margin: 0;">
          Ecosystem guide for AIs — what atoms are, how to navigate from umbrella to catalog,
          atom structure, compositions, signing, and a per-domain catalog map.
        </p>
      </div>
    </div>
    <p style="font-size: 0.875rem; color: var(--muted);">
      Each catalog also exposes its own <code>/ai/index.json</code> (linked as "AI" on every card above).
      The full machine-readable directory is at <a href="/directory.json"><code>/directory.json</code></a>.
      See <a href="/how-to-use/">how-to-use</a> for the complete JSON shape.
    </p>
  </section>
</Base>
